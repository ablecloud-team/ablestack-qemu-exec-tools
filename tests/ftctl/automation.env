# FTCTL real-environment automation configuration

VM_CREATE_MODE=virsh
PERSISTENT_CREATE_MODE=define
TRANSIENT_CREATE_MODE=create

PRIMARY_HOST=ablecube31-1
SECONDARY_HOST=ablecube31-2
PRIMARY_MGMT_IP=10.10.31.1
SECONDARY_MGMT_IP=10.10.31.2

PRIMARY_LIBVIRT_URI=qemu+ssh://10.10.31.1/system
SECONDARY_LIBVIRT_URI=qemu+ssh://10.10.31.2/system

PRIMARY_SSH_USER=root
SECONDARY_SSH_USER=root
SSH_KEY_AUTH=yes
SECONDARY_NEEDS_SUDO=no

LOCAL_QCOW2_ROOT=/var/lib/libvirt/images
LOCAL_RAW_ROOT=/var/lib/libvirt/images
SHARED_PRIMARY_ROOT=/mnt/glue-gfs
SHARED_SECONDARY_ROOT=/mnt/glue-gfs-1
REMOTE_NBD_TARGET_ROOT=/var/lib/ablestack-vm-ftctl/remote-nbd-targets

VM_DEFAULT_VCPU=2
VM_DEFAULT_MEMORY_MB=2048
VM_DEFAULT_MACHINE=q35
VM_DEFAULT_ARCH=x86_64

DEFAULT_BRIDGE=bridge0
DEFAULT_NETWORK_MODE=bridge
DEFAULT_LIBVIRT_NETWORK=default

VM_XML_TEMPLATE_DIR=/root/templates/vm
VM_XML_RUNTIME_DIR=/var/lib/libvirt/xml
VM_DISK_TEMPLATE_DIR=/root/templates/vm

BASE_IMAGE_QCOW2=/var/lib/libvirt/images/rocky10-t.qcow2
BASE_IMAGE_RAW=/var/lib/libvirt/images/rocky10-t.img

SECONDARY_VM_SUFFIX=-standby

FTCTL_REMOTE_NBD_PORT_BASE=10809
FTCTL_REMOTE_NBD_PORT_COUNT=64
FTCTL_REMOTE_NBD_MAX_CONCURRENT=64

TEST_LOG_ROOT=/var/log/ablestack-ftctl-test
KEEP_LOG_BUNDLE=yes
CLEANUP_VM_AFTER_TEST=no
CLEANUP_DISK_AFTER_TEST=no
OBSERVE_DELAY_SEC=10

AUTO_APPLY_FIREWALLD_SERVICE=yes
FIREWALLD_SERVICE_NAME=ablestack-vm-ftctl-remote-nbd

AUTOMATION_TARGET_IDS=HA-IMG08-ST01,HA-IMG02-ST02,HA-IMG05-ST01,HA-IMG09-ST01
