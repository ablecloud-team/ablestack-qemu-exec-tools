TEST_ID=HA-IMG01-ST04
VM_NAME=rocky10-shared
DOMAIN_MODE=persistent
VM_RUNTIME_STATE=running
GUEST_OS_LINUX=yes
PROTECTED_DISK_COUNT=1
RECREATE_VM=1

FTCTL_PROFILE_BACKEND_MODE=shared-blockcopy
FTCTL_PROFILE_TARGET_STORAGE_SCOPE=shared
FTCTL_PROFILE_SECONDARY_VM_NAME=rocky10-shared-standby
FTCTL_PROFILE_SECONDARY_TARGET_DIR=
FTCTL_PROFILE_REMOTE_NBD_EXPORT_ADDR=
FTCTL_PROFILE_REMOTE_NBD_EXPORT_PORT=
FTCTL_PROFILE_REMOTE_NBD_EXPORT_NAME=
FTCTL_PROFILE_DOMAIN_PERSISTENCE=yes

DISK_1_TARGET=vda
DISK_1_PATH=${SHARED_PRIMARY_ROOT}/rocky10-shared.qcow2
DISK_1_FORMAT=qcow2

SHARED_TARGET_PATH=${SHARED_SECONDARY_ROOT}/rocky10-shared-standby.qcow2
