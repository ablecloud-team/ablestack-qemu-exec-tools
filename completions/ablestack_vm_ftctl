_ablestack_vm_ftctl()
{
  local cur prev words cword
  _init_completion -n : || return

  local -a commands=(
    protect status reconcile failover failback fence-confirm fence-clear
    pause-protection resume-protection check health
    config
  )

  local -a global_opts=(
    -h --help -V --version
    --vm --mode --peer --profile --config --policy
    --dry-run --json --force
    --cluster-name --local-host-id --host-id --role
    --management-ip --libvirt-uri --blockcopy-ip
    --xcolo-control-ip --xcolo-data-ip
  )

  case "${prev}" in
    --mode)
      COMPREPLY=( $(compgen -W "ha dr ft" -- "${cur}") )
      return 0
      ;;
    --config)
      COMPREPLY=( $(compgen -f -- "${cur}") )
      return 0
      ;;
    --role)
      COMPREPLY=( $(compgen -W "primary secondary observer generic" -- "${cur}") )
      return 0
      ;;
    --vm|--peer|--profile|--policy|--cluster-name|--local-host-id|--host-id|--management-ip|--libvirt-uri|--blockcopy-ip|--xcolo-control-ip|--xcolo-data-ip)
      return 0
      ;;
  esac

  local cmd=""
  local i=1
  while (( i < cword )); do
    case "${words[i]}" in
      --vm|--mode|--peer|--profile|--config|--policy|--cluster-name|--local-host-id|--host-id|--role|--management-ip|--libvirt-uri|--blockcopy-ip|--xcolo-control-ip|--xcolo-data-ip)
        ((i+=2))
        continue
        ;;
      --dry-run|--json|--force|-h|--help|-V|--version)
        ((i+=1))
        continue
        ;;
      -*)
        ((i+=1))
        continue
        ;;
      *)
        cmd="${words[i]}"
        break
        ;;
    esac
  done

  if [[ -z "${cmd}" ]]; then
    if [[ "${cur}" == -* ]]; then
      COMPREPLY=( $(compgen -W "${global_opts[*]}" -- "${cur}") )
    else
      COMPREPLY=( $(compgen -W "${commands[*]}" -- "${cur}") )
    fi
    return 0
  fi

  case "${cmd}" in
    protect)
      COMPREPLY=( $(compgen -W "--vm --mode --peer --profile --config --policy --dry-run --json" -- "${cur}") )
      ;;
    status|reconcile|check)
      COMPREPLY=( $(compgen -W "--vm --config --policy --dry-run --json" -- "${cur}") )
      ;;
    failover|failback)
      COMPREPLY=( $(compgen -W "--vm --config --policy --json --force" -- "${cur}") )
      ;;
    fence-confirm|fence-clear)
      COMPREPLY=( $(compgen -W "--vm --config --policy" -- "${cur}") )
      ;;
    pause-protection|resume-protection)
      COMPREPLY=( $(compgen -W "--vm --config --policy" -- "${cur}") )
      ;;
    health)
      COMPREPLY=( $(compgen -W "--config --policy --json" -- "${cur}") )
      ;;
    config)
      COMPREPLY=( $(compgen -W "init-cluster set-local-host show host-upsert host-remove host-list --config --policy --json --cluster-name --local-host-id --host-id --role --management-ip --libvirt-uri --blockcopy-ip --xcolo-control-ip --xcolo-data-ip" -- "${cur}") )
      ;;
    *)
      COMPREPLY=()
      ;;
  esac
}

complete -F _ablestack_vm_ftctl ablestack_vm_ftctl
