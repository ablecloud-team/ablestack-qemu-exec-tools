<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package
    Name="AbleStack QEMU Exec Tools $(var.ProductVersion)-$(var.ProductRelease)-$(var.GitHash)"
    Manufacturer="ABLECLOUD"
    Version="$(var.ProductVersion)"
    Scope="perMachine"
    UpgradeCode="2B9C6E7A-7C6E-4EBA-A2F7-7A5D2C2C0A01">

    <MediaTemplate />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />

    <!-- Ž≤Ąž†Ą/Ž¶īŽ¶¨ž¶?ÍĻÉŪēī?úŽ? MSI PropertyŽ°??Ä??-->
    <Property Id="PRODUCT_VERSION" Value="$(var.ProductVersion)" />
    <Property Id="PRODUCT_RELEASE" Value="$(var.ProductRelease)" />
    <Property Id="PRODUCT_GITHASH" Value="$(var.GitHash)" />

    <!-- x64 install location; requires -arch x64 at build -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="AbleStack\CloudInit">
        <Directory Id="LOCALSCRIPTS" Name="LocalScripts" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="APPDATAABL" Name="AbleStack\CloudInit">
        <Directory Id="APPDATALOGS" Name="Logs" />
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Core" Level="1">
      <ComponentRef Id="cmpPhaseRunner" />
      <ComponentRef Id="cmpAssets" />
      <ComponentRef Id="cmpUnattendServer" />
      <ComponentRef Id="cmpUnattendClient" />
      <ComponentRef Id="cmpLocalScripts" />
      <ComponentRef Id="RegPhaseSeed" />
      <ComponentRef Id="RegInstallInfo" />
    </Feature>

    <!-- ========== Reboot policy (Manual / Auto) ========== -->
    <!-- ÍłįŽ≥ł: Manual ???¨Ž????Ķž†ú(3010 ŽįėŪôė). Auto ?Ēž≤≠ ??Íįēž†ú ?¨Ž???-->
    <Property Id="REBOOTMODE" Value="Manual" />
    <SetProperty Id="SetRebootManual"
                Value="ReallySuppress"
                Before="InstallValidate"
                Sequence="execute"
                Condition="REBOOTMODE=&quot;Manual&quot;" />

    <!-- Auto: ?§žĻė žĘÖŽ£Ć žßĀŪõĄ ?źŽŹô ?¨Ž???-->
    <SetProperty Id="SetRebootAuto"
                Value="Force"
                Before="InstallValidate"
                Sequence="execute"
                Condition="REBOOTMODE=&quot;Auto&quot;" />

    <!-- ?§žĻė/?úÍĪį ?Ěžóź???¨Ž????ĄžöĒ ?ĆŽěėÍ∑??§ž†ē -->
    <InstallExecuteSequence>
      <ScheduleReboot Before="InstallFinalize"
                      Condition="(NOT Installed) OR (REMOVE=&quot;ALL&quot;)" />
    </InstallExecuteSequence>

    <!-- ========== Scheduled Tasks via schtasks.exe + WixQuietExec ========== -->
    <!-- ?ĎžóÖ ?īŽ¶Ą -->
    <Property Id="TASK_NAME_BOOT"  Value="AbleStack-CloudInit-PhaseRunner-Boot"/>
    <Property Id="TASK_NAME_LOGON" Value="AbleStack-CloudInit-PhaseRunner-Logon"/>

    <!-- ===== PropertiesŽ•??§ž†ē?ėŽäĒ CustomAction??===== -->
    <!-- Boot ?łŽ¶¨ÍĪ?-->
    <CustomAction Id="SetCreateBootTask"
      Property="CreateBootTask"
      Value="&quot;[System64Folder]schtasks.exe&quot; /Create /TN &quot;[TASK_NAME_BOOT]&quot; /SC ONSTART /RU SYSTEM /RL HIGHEST /TR &quot;%SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File \&quot;[INSTALLDIR]phase-runner.ps1\&quot; -SysprepAfterPhase2&quot; /F" />

    <!-- Logon ?łŽ¶¨ÍĪ?-->
    <CustomAction Id="SetCreateLogonTask"
      Property="CreateLogonTask"
      Value="&quot;[System64Folder]schtasks.exe&quot; /Create /TN &quot;[TASK_NAME_LOGON]&quot; /SC ONLOGON /RU SYSTEM /RL HIGHEST /TR &quot;%SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File \&quot;[INSTALLDIR]phase-runner.ps1\&quot; -SysprepAfterPhase2&quot; /F" />

    <!-- ??†ú -->
    <CustomAction Id="SetDeleteBootTask"
      Property="DeleteBootTask"
      Value="&quot;[System64Folder]schtasks.exe&quot; /Delete /TN &quot;[TASK_NAME_BOOT]&quot; /F" />

    <CustomAction Id="SetDeleteLogonTask"
      Property="DeleteLogonTask"
      Value="&quot;[System64Folder]schtasks.exe&quot; /Delete /TN &quot;[TASK_NAME_LOGON]&quot; /F" />



    <!-- ===== ?§ž†ú ?§ŪĖČ?ėŽäĒ QuietExec CustomAction??(Íłįž°īÍ≥??ôžĚľ) ===== -->
    <!-- ?īŽ? ?¨žö© ž§ĎžĚł WixQuietExec ÍłįŽįė CA ?ēžĚėŽ•??†ž??©Žčą?? -->
    <CustomAction Id="CreateBootTask"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec" Execute="deferred" Impersonate="no" Return="check" />

    <CustomAction Id="CreateLogonTask"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec" Execute="deferred" Impersonate="no" Return="check" />

    <CustomAction Id="DeleteBootTask"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec" Execute="deferred" Impersonate="no" Return="check" />

    <CustomAction Id="DeleteLogonTask"
      BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
      DllEntry="WixQuietExec" Execute="deferred" Impersonate="no" Return="check" />


    <!-- ===== ?§ŪĖČ ?úžĄú (Íłįž°ī ?źŽ¶Ą ?†ž?; ?ĄžöĒ ???ĄŽěėž≤ėŽüľ Ž™Öžčú) ===== -->
    <InstallExecuteSequence>
      <!-- ?§žĻė/?ÖÍ∑ł?ąžĚī??-->
      <Custom Action="SetCreateBootTask"   After="InstallFiles"       Condition="NOT REMOVE" />
      <Custom Action="CreateBootTask"      After="SetCreateBootTask"  Condition="NOT REMOVE" />
      <Custom Action="SetCreateLogonTask"  After="CreateBootTask"     Condition="NOT REMOVE" />
      <Custom Action="CreateLogonTask"     After="SetCreateLogonTask" Condition="NOT REMOVE" />

      <!-- ?úÍĪį -->
      <Custom Action="SetDeleteLogonTask"  Before="RemoveFiles"       Condition="REMOVE" />
      <Custom Action="DeleteLogonTask"     After="SetDeleteLogonTask" Condition="REMOVE" />
      <Custom Action="SetDeleteBootTask"   After="DeleteLogonTask"    Condition="REMOVE" />
      <Custom Action="DeleteBootTask"      After="SetDeleteBootTask"  Condition="REMOVE" />
    </InstallExecuteSequence>

  </Package>

  <!-- Files -->
  <Fragment>
    <Component Id="cmpPhaseRunner" Directory="INSTALLDIR" Guid="{6C6AF2F6-6D86-4A40-9F24-2B2D0C9D0D10}">
      <File Id="filPhaseRunner" Source="$(var.SourceDir)\phase-runner.ps1" KeyPath="yes" />
    </Component>

    <Component Id="cmpAssets" Directory="INSTALLDIR" Guid="{A8C5E3B4-1D2F-4F9D-A7E8-4C3A7D85C1F2}">
      <File Id="filCloudbaseInitConf" Source="$(var.SourceDir)\assets\cloudbase-init.conf" KeyPath="yes" />
      <File Id="filCloudbaseInitUnattendConf" Source="$(var.SourceDir)\assets\cloudbase-init-unattend.conf" />
      <File Id="filInstallCbiPs1" Source="$(var.SourceDir)\assets\install_cloudbase_init.ps1" />
      <!-- Optional vendor MSI bundling -->
      <File Id="filCloudbaseMsi" Source="$(var.SourceDir)\assets\CloudbaseInitSetup_x64.msi" />
    </Component>

    <Component Id="cmpUnattendServer" Directory="INSTALLDIR" Condition="MsiNTProductType=3" Guid="{D4F5E6A7-B8C9-4D0E-9F1A-2B3C4D5E6F70}">
      <File Id="filUnattendServer"
            Name="unattend.xml"
            Source="$(var.SourceDir)\assets\unattend-server2025.xml"
            KeyPath="yes" />
    </Component>

    <Component Id="cmpUnattendClient" Directory="INSTALLDIR" Condition="MsiNTProductType=1" Guid="{F1E2D3C4-B5A6-4789-8A9B-0C1D2E3F4A50}">
      <File Id="filUnattendClient"
            Name="unattend.xml"
            Source="$(var.SourceDir)\assets\unattend-windows11.xml"
            KeyPath="yes" />
    </Component>

    <Component Id="cmpLocalScripts" Directory="LOCALSCRIPTS" Guid="{BCE7A9B7-8F3B-44E5-9F4B-1E7C33A6F4D2}">
      <File Id="filResetCbiPluginState"
            Source="$(var.SourceDir)\assets\99-reset-cbi-plugin-state.ps1"
            Name="99-reset-cbi-plugin-state.ps1"
            KeyPath="yes" />
    </Component>

    <Component Id="RegPhaseSeed" Directory="INSTALLDIR" Guid="{E1B7B3D9-5B6A-4F7C-B2B4-9C7F6E2B1A4C}">
      <RegistryKey Root="HKLM" Key="SOFTWARE\AbleStack\CloudInit">
        <RegistryValue Name="Phase" Type="string" Value="1" KeyPath="yes" />
      </RegistryKey>
    </Component>

    <!-- Write Installation Information to registry -->
    <Component Id="RegInstallInfo" Directory="INSTALLDIR" Guid="{A8B6D7B3-9D23-4D5C-9A53-7F9B8B6A1F10}">
      <RegistryKey Root="HKLM" Key="SOFTWARE\AbleStack\QemuExecTools">
        <RegistryValue Name="Version" Type="string" Value="[PRODUCT_VERSION]" KeyPath="yes" />
        <RegistryValue Name="Release" Type="string" Value="[PRODUCT_RELEASE]" />
        <RegistryValue Name="GitHash" Type="string" Value="[PRODUCT_GITHASH]" />
        <RegistryValue Name="InstallDir" Type="string" Value="[INSTALLDIR]" />
      </RegistryKey>
    </Component>
  </Fragment>
</Wix>
